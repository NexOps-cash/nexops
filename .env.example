# Copy to .env.local and fill in values for local development.

# Server-side Groq key (optional if using BYOK in the browser)
GROQ_API_KEY=

# WalletConnect v2 project id — https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Supabase project (required for auth, projects sync, registry publish)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
